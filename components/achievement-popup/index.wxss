.achievement-popup-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(15, 23, 42, 0.5);
  z-index: 120;
  opacity: 0;
  animation: achievementMaskFade 220ms ease forwards;
}

.achievement-popup-panel {
  position: fixed;
  left: 50%;
  top: 50%;
  width: 580rpx;
  padding: 46rpx 36rpx 34rpx;
  transform: translate(-50%, -50%);
  border-radius: 40rpx;
  background:
    radial-gradient(circle at top, rgba(153, 246, 228, 0.85), transparent 42%),
    linear-gradient(180deg, #ffffff 0%, #f8fffd 100%);
  text-align: center;
  box-shadow: 0 32rpx 80rpx rgba(15, 118, 110, 0.2);
  z-index: 121;
  overflow: hidden;
  animation: achievementPopupIn 320ms ease both;
}

.achievement-popup-halo {
  position: absolute;
  left: 50%;
  top: 48rpx;
  width: 220rpx;
  height: 220rpx;
  margin-left: -110rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, rgba(45, 212, 191, 0.22) 0%, rgba(45, 212, 191, 0) 70%);
  animation: haloPulse 2.4s ease-in-out infinite;
}

.achievement-popup-star {
  position: absolute;
  top: 34rpx;
  color: #14b8a6;
  font-size: 34rpx;
  animation: starFloat 2.6s ease-in-out infinite;
}

.achievement-popup-star-left {
  left: 42rpx;
}

.achievement-popup-star-right {
  right: 42rpx;
  animation-delay: 0.4s;
}

.achievement-popup-cover {
  position: relative;
  display: block;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
  border: 10rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 36rpx rgba(20, 184, 166, 0.22);
}

.achievement-popup-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 50rpx;
  padding: 0 18rpx;
  margin-bottom: 16rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #0f766e;
  font-size: 20rpx;
  font-weight: 700;
}

.achievement-popup-name {
  position: relative;
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
}

.achievement-popup-desc {
  margin: 18rpx auto 14rpx;
  width: 88%;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.achievement-popup-date {
  margin-bottom: 22rpx;
  font-size: 20rpx;
  color: #0f766e;
  font-weight: 600;
}

.achievement-popup-btn {
  position: relative;
}

@keyframes achievementMaskFade {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}

@keyframes achievementPopupIn {
  0% {
    opacity: 0;
    transform: translate(-50%, -46%) scale(0.86);
  }
  72% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.03);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

@keyframes haloPulse {
  0%,
  100% {
    transform: scale(0.92);
    opacity: 0.7;
  }
  50% {
    transform: scale(1.08);
    opacity: 1;
  }
}

@keyframes starFloat {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}
