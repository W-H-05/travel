/* ==================== 路线地图页面 ==================== */

.route-map-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.route-map {
  width: 100%;
  height: 100%;
}

/* ==================== 3D 视角控制按钮 ==================== */

.map-controls {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.map-ctrl-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.1);
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
}

/* ==================== 动画进度覆盖层 ==================== */

.route-anim-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 20;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  animation: popIn 300ms ease both;
}

@keyframes popIn {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

.route-anim-progress {
  width: 240rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e2e8f0;
  overflow: hidden;
}

.route-anim-bar {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #14b8a6 0%, #0d9488 100%);
  transition: width 50ms linear;
}

.route-anim-text {
  font-size: 22rpx;
  color: #475569;
  font-weight: 500;
}

/* ==================== 地图信息卡片 ==================== */

.map-info-sheet {
  position: absolute;
  top: 20rpx;
  left: 24rpx;
  right: 100rpx;
  z-index: 10;
  animation: slideDown 260ms ease both;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.map-info-card {
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.12);
}

.map-info-time {
  font-size: 20rpx;
  color: #0f766e;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.map-info-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
}

.map-info-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
}

/* ==================== 底部路线时间线 ==================== */

.route-timeline-shell {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  max-height: 360rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -8rpx 32rpx rgba(15, 23, 42, 0.08);
  padding-bottom: env(safe-area-inset-bottom);
  animation: slideUp 280ms ease both;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.route-timeline-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 24rpx 14rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.route-timeline-icon {
  font-size: 28rpx;
}

.route-timeline-badge {
  margin-left: auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #0f766e;
  font-size: 20rpx;
  font-weight: 600;
}

.route-timeline-scroll {
  max-height: 280rpx;
  padding: 0 24rpx 16rpx;
}

/* ==================== 时间线项 ==================== */

.timeline-item {
  display: flex;
  padding: 14rpx 0;
  transition: all 0.2s;
}

.timeline-dot-shell {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #cbd5e1;
  border: 3rpx solid #ffffff;
  box-shadow: 0 0 0 2rpx #cbd5e1;
  flex-shrink: 0;
  transition: all 0.25s;
}

.timeline-dot-start {
  background: #0f766e;
  box-shadow: 0 0 0 3rpx rgba(15, 118, 110, 0.3);
  width: 20rpx;
  height: 20rpx;
}

.timeline-dot-end {
  background: #0d9488;
  box-shadow: 0 0 0 3rpx rgba(13, 148, 136, 0.3);
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  margin: 6rpx 0;
  background: #e2e8f0;
  border-radius: 1rpx;
}

.timeline-content {
  flex: 1;
  margin-left: 14rpx;
  padding-bottom: 14rpx;
}

.timeline-item:last-child .timeline-content {
  padding-bottom: 0;
}

.timeline-time {
  font-size: 20rpx;
  color: #0f766e;
  font-weight: 600;
}

.timeline-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #0f172a;
  margin-top: 2rpx;
  line-height: 1.4;
}

.timeline-desc {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 2rpx;
  line-height: 1.4;
}

/* ==================== 激活态 ==================== */

.timeline-item-active .timeline-dot {
  background: #14b8a6;
  box-shadow: 0 0 0 4rpx rgba(20, 184, 166, 0.25);
  border-color: rgba(20, 184, 166, 0.15);
}

.timeline-item-active .timeline-label {
  color: #14b8a6;
}

/* ==================== 通用 ==================== */

.tap-scale {
  transition: transform 0.15s;
}

.tap-scale:active {
  transform: scale(0.97);
}