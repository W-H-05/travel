.checkin-location {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 28rpx;
  animation: fadeUp 420ms ease both;
}

.checkin-location-icon {
  margin-right: 18rpx;
  font-size: 40rpx;
}

.checkin-location-main {
  flex: 1;
}

.checkin-location-label {
  font-size: 22rpx;
  color: #0f766e;
  font-weight: 700;
}

.checkin-location-primary {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.5;
}

.checkin-location-value {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.6;
}

.checkin-location-note {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.checkin-location-actions {
  display: flex;
  align-items: center;
  margin-left: 18rpx;
}

.checkin-location-btn {
  min-width: 144rpx;
}

.checkin-requirements {
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
}

.checkin-requirement {
  display: flex;
  align-items: center;
  min-height: 56rpx;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #64748b;
}

.checkin-requirement:last-child {
  margin-bottom: 0;
}

.checkin-requirement-dot {
  width: 16rpx;
  height: 16rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: #cbd5e1;
  flex-shrink: 0;
}

.checkin-requirement-active {
  color: #0f766e;
  font-weight: 600;
}

.checkin-requirement-active .checkin-requirement-dot {
  background: #14b8a6;
  box-shadow: 0 0 0 8rpx rgba(20, 184, 166, 0.12);
}

.checkin-title {
  margin: 30rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.checkin-upload {
  height: 360rpx;
  border-radius: 28rpx;
  overflow: hidden;
  border: 2rpx dashed rgba(20, 184, 166, 0.28);
  background: #f8fafc;
  animation: fadeUp 480ms ease both;
}

.checkin-upload-image {
  width: 100%;
  height: 100%;
}

.checkin-upload-empty {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
}

.checkin-upload-icon {
  font-size: 64rpx;
  margin-bottom: 14rpx;
}

.checkin-upload-text {
  font-size: 24rpx;
}

.checkin-textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  border-radius: 28rpx;
  background: #f8fafc;
  font-size: 26rpx;
  line-height: 1.7;
}

.checkin-modal {
  text-align: center;
}

.checkin-modal-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #16a34a;
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.checkin-modal-image-wrap {
  width: 100%;
  height: 260rpx;
  margin: 24rpx 0 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f8fafc;
}

.checkin-modal-image {
  width: 100%;
  height: 100%;
}

.checkin-modal-placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
}

.checkin-modal-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}
