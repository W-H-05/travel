.friends-page {
  padding-bottom: 120rpx;
}

.friends-tabs {
  display: flex;
  justify-content: center;
  padding: 20rpx 24rpx 0;
}

.friends-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 172rpx;
  min-height: 78rpx;
  margin: 0 12rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.friends-tab-active {
  background: linear-gradient(135deg, #14b8a6 0%, #0f766e 100%);
  color: #ffffff;
}

.friends-filters {
  padding-bottom: 0;
}

.friends-filter-block {
  margin-bottom: 18rpx;
}

.friends-filter-label {
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.friends-chip-row {
  display: flex;
  flex-wrap: wrap;
}

.friends-chip {
  min-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  margin-right: 14rpx;
  margin-bottom: 14rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.friends-chip-active {
  background: #ccfbf1;
  color: #0f766e;
}

.friends-card {
  padding: 26rpx;
  margin-bottom: 20rpx;
  animation: fadeUp 420ms ease both;
}

.friends-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.friends-card-user {
  display: flex;
  align-items: center;
}

.friends-avatar {
  width: 92rpx;
  height: 92rpx;
  margin-right: 18rpx;
  border-radius: 999rpx;
}

.friends-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.friends-hobbies {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #0f766e;
}

.friends-gender {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.friends-gender-female {
  background: #fce7f3;
  color: #db2777;
}

.friends-gender-male {
  background: #dbeafe;
  color: #2563eb;
}

.friends-desc {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.friends-actions {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
}

.friends-action-primary,
.friends-action-outline {
  flex: 1;
}

.friends-action-primary {
  margin-right: 14rpx;
}

.friends-action-disabled {
  pointer-events: none;
}

.friends-action-outline {
  margin-left: 0;
}

.friends-delete {
  margin-top: 22rpx;
}

.friends-fab {
  position: fixed;
  right: 30rpx;
  bottom: calc(30rpx + env(safe-area-inset-bottom));
  font-size: 52rpx;
  line-height: 1;
  box-shadow: 0 16rpx 36rpx rgba(20, 184, 166, 0.28);
}

.publish-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 36rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  z-index: 91;
}

.publish-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 22rpx;
}

.publish-input,
.publish-textarea {
  width: 100%;
  padding: 22rpx 24rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  font-size: 24rpx;
}

.publish-input {
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
}

.publish-input-placeholder {
  color: #94a3b8;
  line-height: 88rpx;
}

.publish-textarea {
  height: 180rpx;
  line-height: 1.7;
}

.wx-modal {
  text-align: center;
}

.wx-modal-icon {
  font-size: 64rpx;
}

.wx-modal-title {
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.wx-modal-text {
  margin: 16rpx 0 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.wx-modal-code {
  padding: 22rpx;
  margin-bottom: 28rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}
