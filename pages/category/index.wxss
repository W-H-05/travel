.category-title {
  margin-bottom: 28rpx;
}

.category-grid {
  margin-top: 8rpx;
}

.category-card {
  position: relative;
  height: 210rpx;
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.08);
}

.category-card-image {
  width: 100%;
  height: 100%;
}

.category-card-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.12), rgba(15, 23, 42, 0.48));
}

.category-card-name {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
  font-weight: 700;
}
