<view class="page-shell safe-bottom">
  <view wx:if="{{user}}" class="profile-top">
    <image class="profile-avatar" src="{{user.avatar}}" mode="aspectFill"></image>
    <view class="profile-name">{{user.nickname}}</view>
    <view class="profile-points">绿色积分 {{user.greenPoints}}</view>
  </view>

  <view wx:if="{{!user}}" class="page-padding">
    <view class="card login-prompt">
      <view class="login-prompt-icon">👋</view>
      <view class="section-title">登录后解锁完整旅行档案</view>
      <view class="section-subtitle login-prompt-text">收藏、公益活动、成就和足迹记录都会保存在这里。</view>
      <view class="ui-btn ui-btn-primary ui-btn-block" bindtap="goLogin" hover-class="tap-scale">去登录</view>
    </view>
  </view>

  <view wx:if="{{user}}" class="profile-content">
    <view class="profile-stats">
      <view class="card profile-stat" data-url="/pages/my-footprints/index" bindtap="openPage">
        <view class="profile-stat-icon">👣</view>
        <view class="profile-stat-value">{{user.footprints}}</view>
        <view class="profile-stat-label">足迹打卡</view>
      </view>
      <view class="card profile-stat" data-url="/pages/achievements/index" bindtap="openPage">
        <view class="profile-stat-icon">🏅</view>
        <view class="profile-stat-value">{{unlockedCount}}</view>
        <view class="profile-stat-label">获得成就</view>
      </view>
    </view>

    <view class="page-padding profile-section">
      <view class="section-title profile-section-title">荣誉墙</view>
      <scroll-view scroll-x class="achievement-scroll">
        <view class="achievement-row">
          <view wx:for="{{achievements}}" wx:key="id" class="achievement-card" data-index="{{index}}" bindtap="previewAchievement">
            <image class="achievement-image {{item.date === '--' ? 'achievement-image-muted' : ''}}" src="{{item.image}}" mode="aspectFill"></image>
            <view class="achievement-name">{{item.name}}</view>
            <view class="achievement-date">{{item.date === '--' ? '未解锁' : item.date}}</view>
          </view>
        </view>
      </scroll-view>

      <view class="menu-list">
        <view class="menu-item" data-url="/pages/favorites/index" bindtap="openPage">
          <text class="menu-icon">⭐</text>
          <text class="menu-label">我的收藏</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" data-url="/pages/my-activities/index" bindtap="openPage">
          <text class="menu-icon">🌱</text>
          <text class="menu-label">公益活动</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item">
          <text class="menu-icon">⚙️</text>
          <text class="menu-label">账号设置</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item">
          <text class="menu-icon">❓</text>
          <text class="menu-label">常见问题</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="ui-btn ui-btn-danger ui-btn-block logout-btn" bindtap="handleLogout" hover-class="tap-scale">退出登录</view>
    </view>
  </view>

  <view wx:if="{{selectedAchievement}}" class="modal-mask" bindtap="closeAchievement"></view>
  <view wx:if="{{selectedAchievement}}" class="modal-panel achievement-modal">
    <image class="achievement-modal-image {{selectedAchievement.date === '--' ? 'achievement-image-muted' : ''}}" src="{{selectedAchievement.image}}" mode="aspectFill"></image>
    <view class="achievement-modal-name">{{selectedAchievement.name}}</view>
    <view class="achievement-modal-date">{{selectedAchievement.date === '--' ? '尚未解锁' : ('解锁于 ' + selectedAchievement.date)}}</view>
    <view class="achievement-modal-desc">{{selectedAchievement.description}}</view>
    <view class="ui-btn ui-btn-primary ui-btn-block" bindtap="closeAchievement" hover-class="tap-scale">我知道了</view>
  </view>
</view>
