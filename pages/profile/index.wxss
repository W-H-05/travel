.profile-top {
  padding: 56rpx 32rpx 108rpx;
  background: linear-gradient(160deg, #14b8a6 0%, #0f766e 100%);
  border-bottom-left-radius: 52rpx;
  border-bottom-right-radius: 52rpx;
  text-align: center;
  color: #ffffff;
  animation: fadeUp 420ms ease both;
}

.profile-avatar {
  width: 156rpx;
  height: 156rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.22);
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
}

.profile-points {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

.profile-content {
  margin-top: -56rpx;
}

.profile-stats {
  display: flex;
  padding: 0 32rpx;
}

.profile-stat {
  flex: 1;
  padding: 28rpx 20rpx;
  text-align: center;
  animation: fadeUp 520ms ease both;
}

.profile-stat:first-child {
  margin-right: 24rpx;
}

.profile-stat-icon {
  display: block;
  margin-bottom: 10rpx;
  font-size: 40rpx;
}

.profile-stat-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #0f766e;
}

.profile-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.profile-section {
  padding-top: 36rpx;
}

.profile-section-title {
  margin-bottom: 24rpx;
}

.achievement-scroll {
  white-space: nowrap;
}

.achievement-row {
  display: inline-flex;
}

.achievement-card {
  width: 190rpx;
  margin-right: 20rpx;
  padding: 24rpx 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
  text-align: center;
}

.achievement-image,
.achievement-modal-image {
  border-radius: 999rpx;
}

.achievement-image {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 16rpx;
}

.achievement-image-muted {
  filter: grayscale(100%);
  opacity: 0.45;
}

.achievement-name {
  font-size: 22rpx;
  font-weight: 700;
  color: #334155;
}

.achievement-date {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #94a3b8;
}

.menu-list {
  margin-top: 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.menu-icon {
  width: 48rpx;
  margin-right: 18rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
  font-weight: 500;
}

.menu-arrow {
  color: #cbd5e1;
  font-size: 38rpx;
}

.logout-btn {
  margin-top: 28rpx;
}

.login-prompt {
  padding: 44rpx 36rpx;
  text-align: center;
}

.login-prompt-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.login-prompt-text {
  margin: 16rpx 0 32rpx;
  line-height: 1.7;
}

.achievement-modal {
  text-align: center;
}

.achievement-modal-image {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
}

.achievement-modal-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.achievement-modal-date {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #0f766e;
}

.achievement-modal-desc {
  margin: 28rpx 0 32rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.7;
}
