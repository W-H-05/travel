.fav-card {
  position: relative;
  overflow: hidden;
}

.fav-image {
  width: 100%;
  height: 260rpx;
}

.fav-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #0f766e;
  font-size: 18rpx;
  font-weight: 700;
}

.fav-body {
  padding: 22rpx;
}

.fav-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.fav-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}
