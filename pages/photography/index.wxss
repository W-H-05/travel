.photo-filter {
  white-space: nowrap;
  padding: 20rpx 24rpx 0;
}

.photo-filter-row {
  display: inline-flex;
}

.photo-chip {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 26rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
}

.photo-chip-active {
  background: linear-gradient(135deg, #14b8a6 0%, #0f766e 100%);
  color: #ffffff;
}

.photo-card {
  overflow: hidden;
  animation: fadeUp 420ms ease both;
}

.photo-card-image {
  width: 100%;
  height: 420rpx;
}

.photo-card-body {
  padding: 22rpx;
}

.photo-card-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
}

.photo-card-author {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #94a3b8;
}
