.footprint-card {
  margin-bottom: 24rpx;
  overflow: hidden;
}

.footprint-image-wrap {
  width: 100%;
  height: 360rpx;
  background: #f8fafc;
}

.footprint-image {
  width: 100%;
  height: 100%;
}

.footprint-placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
}

.footprint-body {
  padding: 24rpx;
}

.footprint-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.footprint-location {
  font-size: 22rpx;
  color: #0f766e;
  font-weight: 700;
}

.footprint-date {
  font-size: 20rpx;
  color: #94a3b8;
}

.footprint-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}
