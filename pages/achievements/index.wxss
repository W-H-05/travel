.achievement-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  margin-bottom: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #14b8a6 0%, #34d399 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(20, 184, 166, 0.22);
}

.achievement-summary-label {
  font-size: 24rpx;
  opacity: 0.88;
}

.achievement-summary-value {
  margin-top: 10rpx;
  font-size: 46rpx;
  font-weight: 700;
}

.achievement-summary-total {
  font-size: 24rpx;
  opacity: 0.86;
}

.achievement-summary-icon {
  font-size: 72rpx;
}

.achievement-list-card {
  padding: 26rpx 22rpx;
  text-align: center;
}

.achievement-list-image {
  width: 110rpx;
  height: 110rpx;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
}

.achievement-list-image-muted {
  filter: grayscale(100%);
  opacity: 0.4;
}

.achievement-list-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.achievement-list-desc {
  margin-top: 10rpx;
  min-height: 68rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #64748b;
}

.achievement-list-status {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f0fdfa;
  color: #0f766e;
  font-size: 18rpx;
  font-weight: 700;
}

.achievement-list-status-muted {
  background: #f1f5f9;
  color: #94a3b8;
}
