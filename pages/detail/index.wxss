.detail-page {
  padding-bottom: 128rpx;
}

.detail-cover {
  width: 100%;
  height: 420rpx;
}

.detail-head {
  margin: -56rpx 24rpx 0;
  padding: 28rpx;
  position: relative;
  z-index: 2;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.detail-region {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #0f766e;
  font-weight: 600;
}

.detail-tabs {
  display: flex;
  margin-top: 24rpx;
  border-top: 2rpx solid rgba(148, 163, 184, 0.1);
}

.detail-tab {
  flex: 1;
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 600;
  border-bottom: 4rpx solid transparent;
}

.detail-tab-active {
  color: #0f766e;
  border-bottom-color: #14b8a6;
}

.detail-body {
  padding-top: 28rpx;
}

.detail-desc {
  font-size: 26rpx;
  line-height: 1.9;
  color: #475569;
}

.detail-gallery {
  display: flex;
  justify-content: space-between;
  margin: 28rpx 0 36rpx;
  animation: fadeUp 520ms ease both;
}

.detail-gallery-image {
  width: 48.5%;
  height: 220rpx;
  border-radius: 24rpx;
}

.detail-section-title {
  margin-bottom: 22rpx;
}

.detail-tip-list {
  padding: 24rpx 28rpx;
}

.detail-tip-item {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.detail-tip-item:last-child {
  margin-bottom: 0;
}

.review-item {
  display: flex;
  margin-bottom: 28rpx;
}

.review-avatar {
  width: 76rpx;
  height: 76rpx;
  margin-right: 18rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.review-body {
  flex: 1;
}

.review-top {
  display: flex;
  align-items: center;
}

.review-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
}

.review-level {
  margin-left: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f0fdfa;
  color: #0f766e;
  font-size: 18rpx;
}

.review-content {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.review-photo {
  width: 180rpx;
  height: 180rpx;
  margin-top: 16rpx;
  border-radius: 22rpx;
}

.detail-actions {
  display: flex;
  align-items: center;
}

.detail-fav {
  flex: 1;
  margin-right: 16rpx;
}

.detail-fav-active {
  background: #f0fdfa;
  color: #0f766e;
  border-color: rgba(20, 184, 166, 0.24);
}

.detail-add {
  flex: 2;
}
