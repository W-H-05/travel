.home-search-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 30;
  padding: 20rpx 24rpx 18rpx;
  background: linear-gradient(180deg, rgba(245, 250, 248, 0.98) 0%, rgba(245, 250, 248, 0.94) 70%, rgba(245, 250, 248, 0) 100%);
}

.home-search {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 30rpx rgba(15, 118, 110, 0.08);
  backdrop-filter: blur(10rpx);
  animation: fadeUp 360ms ease both;
}

.home-search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.home-search-text {
  font-size: 26rpx;
  color: #94a3b8;
}

.home-main {
  padding-top: 142rpx;
}

.hero-card {
  overflow: hidden;
  animation: fadeUp 420ms ease both;
}

.hero-swiper {
  width: 100%;
  height: 320rpx;
}

.hero-slide {
  position: relative;
  width: 100%;
  height: 100%;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 10%, rgba(15, 23, 42, 0.58) 100%);
}

.hero-text {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 32rpx;
  color: #ffffff;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
}

.hero-region {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.85;
}

.hero-dots {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  display: flex;
}

.hero-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.45);
}

.hero-dot:last-child {
  margin-right: 0;
}

.hero-dot-active {
  width: 28rpx;
  background: #ffffff;
}

.shortcut-row {
  display: flex;
  justify-content: space-between;
  margin-top: 32rpx;
  animation: fadeUp 500ms ease both;
}

.shortcut-item {
  width: 20%;
  text-align: center;
}

.shortcut-icon {
  width: 84rpx;
  height: 84rpx;
  margin: 0 auto 12rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(15, 118, 110, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.shortcut-label {
  font-size: 22rpx;
  color: #475569;
  font-weight: 500;
}

.community-card {
  margin-top: 36rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(240, 253, 250, 0.95) 0%, rgba(236, 253, 245, 0.92) 100%);
  animation: fadeUp 560ms ease both;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-mark {
  margin-right: 12rpx;
  color: #14b8a6;
  font-size: 28rpx;
}

.section-more {
  background: #ffffff;
  color: #0f766e;
  font-size: 20rpx;
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.08);
}

.community-scroll {
  white-space: nowrap;
}

.community-scroll-inner {
  display: inline-flex;
}

.community-cover {
  position: relative;
  width: 180rpx;
  height: 240rpx;
  margin-right: 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
}

.community-cover:last-child {
  margin-right: 0;
}

.community-cover-image {
  width: 100%;
  height: 100%;
}

.community-cover-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 20%, rgba(15, 23, 42, 0.82) 100%);
}

.community-cover-title {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1.5;
  font-weight: 600;
}

.plain-head {
  margin-top: 36rpx;
}

.hot-card {
  overflow: hidden;
  animation: fadeUp 620ms ease both;
}

.hot-card-image {
  width: 100%;
  height: 300rpx;
}

.hot-card-body {
  padding: 24rpx;
}

.hot-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.hot-card-region {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.load-more-btn {
  width: 320rpx;
  margin: 12rpx auto 0;
}
