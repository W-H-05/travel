.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background:
    radial-gradient(circle at top left, rgba(20, 184, 166, 0.18), transparent 46%),
    radial-gradient(circle at bottom right, rgba(16, 185, 129, 0.14), transparent 42%),
    linear-gradient(180deg, #ecfdf5 0%, #f8fafc 100%);
}

.login-card {
  width: 100%;
  max-width: 620rpx;
  padding: 72rpx 48rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 28rpx 70rpx rgba(15, 118, 110, 0.14);
  text-align: center;
}

.login-logo {
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 32rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #14b8a6 0%, #0f766e 100%);
  color: #ffffff;
  font-size: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 36rpx rgba(20, 184, 166, 0.24);
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
}

.login-subtitle {
  margin-top: 12rpx;
  margin-bottom: 64rpx;
  font-size: 26rpx;
  color: rgba(15, 118, 110, 0.72);
}

.login-btn {
  margin-bottom: 24rpx;
}

.login-btn-icon {
  margin-right: 12rpx;
}

.login-agreement {
  margin-top: 48rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #94a3b8;
}
