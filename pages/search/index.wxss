.search-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.search-icon,
.search-clear {
  font-size: 28rpx;
  color: #94a3b8;
}

.search-input {
  flex: 1;
  margin: 0 16rpx;
  font-size: 26rpx;
}

.search-card {
  overflow: hidden;
}

.search-card-image {
  width: 100%;
  height: 300rpx;
}

.search-card-body {
  padding: 24rpx;
}

.search-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.search-card-region {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}
