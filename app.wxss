page {
  background: #f5faf8;
  color: #1f2937;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
textarea,
picker,
scroll-view,
swiper,
swiper-item {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  line-height: 1.2;
  background: transparent;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  animation: pageFadeIn 240ms ease both;
}

.ai-page {
  animation: pageFadeIn 240ms ease both;
}

.page-padding {
  padding: 32rpx;
}

.tap-scale {
  transform: scale(0.98);
  opacity: 0.96;
}

.tap-fade {
  opacity: 0.8;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 14rpx 36rpx rgba(15, 118, 110, 0.08);
}

.card-soft {
  background: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid rgba(13, 148, 136, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(15, 118, 110, 0.05);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.section-subtitle {
  font-size: 24rpx;
  color: #64748b;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f0fdfa;
  color: #0f766e;
  font-size: 20rpx;
}

.ui-btn,
.primary-btn,
.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  min-height: 88rpx;
  padding: 0 30rpx;
  border-radius: 26rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
  transition: transform 180ms ease, opacity 180ms ease, box-shadow 220ms ease;
}

.ui-btn-block,
.primary-btn,
.secondary-btn {
  width: 100%;
}

.ui-btn-primary,
.primary-btn {
  background: linear-gradient(135deg, #14b8a6 0%, #0f766e 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(20, 184, 166, 0.24);
}

.ui-btn-secondary {
  background: linear-gradient(135deg, #ffffff 0%, #f8fffd 100%);
  color: #0f766e;
  border: 2rpx solid rgba(13, 148, 136, 0.14);
  box-shadow: 0 12rpx 26rpx rgba(15, 118, 110, 0.08);
}

.ui-btn-outline {
  background: rgba(255, 255, 255, 0.96);
  color: #0f766e;
  border: 2rpx solid rgba(20, 184, 166, 0.24);
  box-shadow: 0 10rpx 24rpx rgba(15, 118, 110, 0.08);
}

.ui-btn-soft {
  background: #f0fdfa;
  color: #0f766e;
  border: 2rpx solid rgba(20, 184, 166, 0.16);
}

.ui-btn-warning {
  background: linear-gradient(135deg, #fb923c 0%, #f97316 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(249, 115, 22, 0.22);
}

.ui-btn-danger {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(239, 68, 68, 0.22);
}

.ui-btn-disabled {
  background: #e2e8f0;
  color: #64748b;
  box-shadow: none;
}

.ui-btn-pill {
  min-height: 72rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.ui-btn-compact {
  min-height: 76rpx;
  font-size: 24rpx;
}

.ui-btn-circle {
  width: 96rpx;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0;
  border-radius: 999rpx;
}

.ui-btn-icon-text {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ui-btn-icon {
  margin-right: 10rpx;
}

.secondary-btn {
  background: #ffffff;
  color: #0f766e;
  border: 2rpx solid rgba(13, 148, 136, 0.12);
  box-shadow: 0 12rpx 26rpx rgba(15, 118, 110, 0.08);
}

.muted {
  color: #94a3b8;
}

.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
  color: #94a3b8;
}

.empty-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.two-col-grid {
  display: flex;
  flex-wrap: wrap;
  margin-left: -12rpx;
  margin-right: -12rpx;
}

.two-col-item {
  width: 50%;
  padding-left: 12rpx;
  padding-right: 12rpx;
  margin-bottom: 24rpx;
}

.three-col-grid {
  display: flex;
  flex-wrap: wrap;
  margin-left: -8rpx;
  margin-right: -8rpx;
}

.three-col-item {
  width: 33.3333%;
  padding-left: 8rpx;
  padding-right: 8rpx;
  margin-bottom: 16rpx;
}

.safe-bottom {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.fixed-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(15, 23, 42, 0.44);
  z-index: 90;
}

.modal-panel {
  position: fixed;
  left: 50%;
  top: 50%;
  width: 84%;
  transform: translate(-50%, -50%);
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  z-index: 91;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.18);
}

.line-clamp-2 {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.line-clamp-3 {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

@keyframes fadeUp {
  0% {
    opacity: 0;
    transform: translate3d(0, 20rpx, 0);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes pageFadeIn {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}

@keyframes softFloat {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-6rpx);
  }
}

@keyframes popIn {
  0% {
    opacity: 0;
    transform: scale(0.86);
  }
  70% {
    opacity: 1;
    transform: scale(1.04);
  }
  100% {
    transform: scale(1);
  }
}

.animate-fade-up {
  animation: fadeUp 420ms ease both;
}

.animate-float {
  animation: softFloat 3.2s ease-in-out infinite;
}

.animate-pop {
  animation: popIn 320ms ease both;
}
